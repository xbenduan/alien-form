{
  "id": "array-cards",
  "name": "卡片数组演示",
  "description": "使用 ArrayCards 动态增删改联系人",
  "schema": {
    "type": "object",
    "properties": {
      "projectName": {
        "type": "string",
        "title": "项目名称",
        "required": true,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入项目名称"
        }
      },
      "contacts": {
        "type": "array",
        "title": "团队联系人",
        "component": "ArrayCards",
        "decorator": "FormItem",
        "props": {
          "addText": "+ 添加联系人"
        },
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "title": "姓名",
              "required": true,
              "component": "Input",
              "decorator": "FormItem",
              "props": {
                "placeholder": "联系人姓名"
              },
              "validators": [
                {
                  "minLength": 2,
                  "message": "姓名至少 2 个字符"
                }
              ]
            },
            "role": {
              "type": "string",
              "title": "角色",
              "component": "Select",
              "decorator": "FormItem",
              "props": {
                "placeholder": "请选择角色"
              },
              "dataSource": [
                {
                  "label": "开发",
                  "value": "dev"
                },
                {
                  "label": "设计",
                  "value": "design"
                },
                {
                  "label": "产品经理",
                  "value": "pm"
                },
                {
                  "label": "测试",
                  "value": "qa"
                },
                {
                  "label": "负责人",
                  "value": "lead"
                }
              ]
            },
            "email": {
              "type": "string",
              "title": "邮箱",
              "component": "Input",
              "decorator": "FormItem",
              "props": {
                "placeholder": "email@example.com"
              },
              "validators": [
                {
                  "format": "email",
                  "message": "邮箱格式不正确"
                }
              ]
            },
            "isPrimary": {
              "type": "boolean",
              "title": "主要联系人",
              "component": "Switch",
              "decorator": "FormItem"
            }
          }
        }
      },
      "notes": {
        "type": "string",
        "title": "备注",
        "component": "Textarea",
        "decorator": "FormItem",
        "props": {
          "placeholder": "补充备注...",
          "rows": 2
        }
      }
    }
  }
}
