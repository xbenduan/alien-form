{
  "id": "advanced",
  "name": "进阶组件演示",
  "description": "演示 Select 多选、ItemInput、Rating、Switch、DateInput、RadioGroup",
  "schema": {
    "type": "object",
    "properties": {
      "skills": {
        "type": "array",
        "title": "技能（多选）",
        "component": "Select",
        "decorator": "FormItem",
        "props": {
          "multiple": true,
          "placeholder": "请选择技能"
        },
        "dataSource": [
          {
            "label": "JavaScript",
            "value": "js"
          },
          {
            "label": "TypeScript",
            "value": "ts"
          },
          {
            "label": "React",
            "value": "react"
          },
          {
            "label": "Vue",
            "value": "vue"
          },
          {
            "label": "Node.js",
            "value": "node"
          },
          {
            "label": "Python",
            "value": "python"
          },
          {
            "label": "Go",
            "value": "go"
          },
          {
            "label": "Rust",
            "value": "rust"
          }
        ]
      },
      "tags": {
        "type": "array",
        "title": "标签（逐项输入）",
        "component": "ItemInput",
        "decorator": "FormItem",
        "props": {
          "placeholder": "输入后按 Enter 添加标签",
          "maxItems": 5
        }
      },
      "experience": {
        "type": "number",
        "title": "经验评分",
        "component": "Rating",
        "decorator": "FormItem",
        "props": {
          "max": 5,
          "size": "lg"
        }
      },
      "startDate": {
        "type": "string",
        "title": "开始日期",
        "component": "DateInput",
        "decorator": "FormItem"
      },
      "newsletter": {
        "type": "boolean",
        "title": "订阅通知",
        "component": "Switch",
        "decorator": "FormItem"
      },
      "frequency": {
        "type": "string",
        "title": "邮件频率",
        "component": "RadioGroup",
        "decorator": "FormItem",
        "dataSource": [
          {
            "label": "每天",
            "value": "daily"
          },
          {
            "label": "每周",
            "value": "weekly"
          },
          {
            "label": "每月",
            "value": "monthly"
          }
        ],
        "reactions": {
          "visible": {
            "dependencies": {
              "newsletter": "newsletter"
            },
            "type": "expression",
            "expression": "$deps.newsletter === true"
          },
          "required": {
            "dependencies": {
              "newsletter": "newsletter"
            },
            "type": "expression",
            "expression": "$deps.newsletter === true"
          }
        },
        "state": {
          "visible": false
        }
      },
      "notes": {
        "type": "string",
        "title": "补充说明",
        "component": "Textarea",
        "decorator": "FormItem",
        "props": {
          "placeholder": "还有其他信息吗...",
          "rows": 2
        }
      }
    }
  },
  "category": "高级组件",
  "order": 90,
  "tags": [
    "components",
    "readPretty",
    "state"
  ]
}
