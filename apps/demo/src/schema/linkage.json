{
  "id": "linkage",
  "name": "联动演示",
  "description": "字段联动：根据联系方式类型切换显示字段",
  "schema": {
    "type": "object",
    "properties": {
      "contactType": {
        "type": "string",
        "title": "联系方式",
        "required": true,
        "component": "Select",
        "decorator": "FormItem",
        "props": {
          "placeholder": "我们该如何联系你？"
        },
        "dataSource": [
          {
            "label": "邮箱",
            "value": "email"
          },
          {
            "label": "电话",
            "value": "phone"
          },
          {
            "label": "微信",
            "value": "wechat"
          }
        ]
      },
      "emailAddress": {
        "type": "string",
        "title": "邮箱地址",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "your@email.com"
        },
        "validators": [
          {
            "format": "email",
            "message": "邮箱格式不正确"
          }
        ],
        "reactions": {
          "visible": {
            "dependencies": {
              "contactType": "contactType"
            },
            "type": "expression",
            "expression": "$deps.contactType === 'email'"
          },
          "required": {
            "dependencies": {
              "contactType": "contactType"
            },
            "type": "expression",
            "expression": "$deps.contactType === 'email'"
          }
        },
        "state": {
          "visible": false
        }
      },
      "phoneNumber": {
        "type": "string",
        "title": "手机号",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "+86 138 0000 0000"
        },
        "reactions": {
          "visible": {
            "dependencies": {
              "contactType": "contactType"
            },
            "type": "expression",
            "expression": "$deps.contactType === 'phone'"
          },
          "required": {
            "dependencies": {
              "contactType": "contactType"
            },
            "type": "expression",
            "expression": "$deps.contactType === 'phone'"
          }
        },
        "state": {
          "visible": false
        }
      },
      "wechatId": {
        "type": "string",
        "title": "微信号",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入微信号"
        },
        "reactions": {
          "visible": {
            "dependencies": {
              "contactType": "contactType"
            },
            "type": "expression",
            "expression": "$deps.contactType === 'wechat'"
          },
          "required": {
            "dependencies": {
              "contactType": "contactType"
            },
            "type": "expression",
            "expression": "$deps.contactType === 'wechat'"
          }
        },
        "state": {
          "visible": false
        }
      },
      "satisfaction": {
        "type": "number",
        "title": "满意度",
        "component": "Rating",
        "decorator": "FormItem",
        "props": {
          "max": 5
        }
      }
    }
  },
  "category": "响应式联动",
  "order": 70,
  "tags": [
    "reactions",
    "state",
    "dependencies"
  ]
}
