{
  "id": "async-datasource",
  "name": "Async DataSource Demo",
  "description": "Demonstrates async data loading for Select — options fetched from remote API with dependency-driven refetch",
  "schema": {
    "type": "object",
    "properties": {
      "infoSection": {
        "type": "void",
        "title": "Async Select Examples",
        "description": "The dropdowns below load their options from a remote API. The second dropdown depends on the first.",
        "x-component": "FormSection",
        "x-component-props": {
          "bordered": true
        },
        "properties": {
          "country": {
            "type": "string",
            "title": "Country (Async)",
            "required": true,
            "x-component": "Select",
            "x-decorator": "FormItem",
            "x-component-props": {
              "placeholder": "Loading countries..."
            },
            "x-async-data-source": {
              "url": "https://restcountries.com/v3.1/region/asia?fields=name,cca2",
              "transformResponse": "parseCountries",
              "fetchOnMount": true
            }
          },
          "category": {
            "type": "string",
            "title": "Category (Static Async Simulation)",
            "x-component": "Select",
            "x-decorator": "FormItem",
            "x-component-props": {
              "placeholder": "Select category"
            },
            "x-async-data-source": {
              "service": "fetchCategories",
              "fetchOnMount": true
            }
          },
          "subCategory": {
            "type": "string",
            "title": "Sub-Category (Depends on Category)",
            "x-component": "Select",
            "x-decorator": "FormItem",
            "x-component-props": {
              "placeholder": "Select sub-category (pick a category first)"
            },
            "x-async-data-source": {
              "service": "fetchSubCategories",
              "dependencies": {
                "category": "category"
              },
              "fetchOnMount": false
            }
          }
        }
      },
      "note": {
        "type": "string",
        "title": "Additional Notes",
        "x-component": "Textarea",
        "x-decorator": "FormItem",
        "x-component-props": {
          "placeholder": "Any additional notes...",
          "rows": 3
        }
      }
    }
  }
}
