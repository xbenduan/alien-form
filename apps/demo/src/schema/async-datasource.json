{
  "id": "async-datasource",
  "name": "异步数据源演示",
  "description": "演示 Select 的异步数据加载与依赖联动刷新",
  "schema": {
    "type": "object",
    "properties": {
      "infoSection": {
        "type": "void",
        "title": "异步选择示例",
        "description": "下面的下拉框会从远程接口加载选项，第二个下拉框依赖第一个的选择。",
        "component": "FormSection",
        "props": {
          "bordered": true
        },
        "properties": {
          "country": {
            "type": "string",
            "title": "国家（异步）",
            "required": true,
            "component": "Select",
            "decorator": "FormItem",
            "props": {
              "placeholder": "国家加载中..."
            },
            "asyncDataSource": {
              "url": "https://restcountries.com/v3.1/region/asia?fields=name,cca2",
              "transformResponse": "parseCountries",
              "fetchOnMount": true
            }
          },
          "category": {
            "type": "string",
            "title": "分类（本地异步模拟）",
            "component": "Select",
            "decorator": "FormItem",
            "props": {
              "placeholder": "请选择分类"
            },
            "asyncDataSource": {
              "service": "fetchCategories",
              "fetchOnMount": true
            }
          },
          "subCategory": {
            "type": "string",
            "title": "子分类（依赖分类）",
            "component": "Select",
            "decorator": "FormItem",
            "props": {
              "placeholder": "请选择子分类（请先选择分类）"
            },
            "asyncDataSource": {
              "service": "fetchSubCategories",
              "dependencies": {
                "category": "category"
              },
              "fetchOnMount": false
            }
          }
        }
      },
      "note": {
        "type": "string",
        "title": "补充说明",
        "component": "Textarea",
        "decorator": "FormItem",
        "props": {
          "placeholder": "还有其他补充吗？",
          "rows": 3
        }
      }
    }
  }
}
