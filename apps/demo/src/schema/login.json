{
  "id": "login",
  "name": "登录表单",
  "description": "基础登录表单，包含用户名和密码",
  "schema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "title": "用户名",
        "required": true,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入用户名"
        }
      },
      "password": {
        "type": "string",
        "title": "密码",
        "required": true,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "type": "password",
          "placeholder": "请输入密码"
        }
      },
      "remember": {
        "type": "boolean",
        "title": "记住我",
        "component": "Checkbox",
        "decorator": "FormItem"
      }
    }
  },
  "category": "基础表单",
  "order": 10,
  "tags": [
    "component",
    "props",
    "validators"
  ]
}
