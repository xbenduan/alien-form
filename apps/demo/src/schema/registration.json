{
  "id": "registration",
  "name": "注册表单",
  "description": "完整注册表单，包含校验、选择器和日期输入",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "title": "姓名",
        "required": true,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入姓名"
        },
        "validators": [
          {
            "minLength": 2,
            "message": "姓名至少 2 个字符"
          }
        ]
      },
      "email": {
        "type": "string",
        "title": "邮箱",
        "required": true,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "example@email.com"
        },
        "validators": [
          {
            "format": "email",
            "message": "邮箱格式不正确"
          }
        ]
      },
      "birthday": {
        "type": "string",
        "title": "生日",
        "component": "DateInput",
        "decorator": "FormItem",
        "props": {
          "max": "2010-01-01"
        }
      },
      "gender": {
        "type": "string",
        "title": "性别",
        "component": "RadioGroup",
        "decorator": "FormItem",
        "props": {
          "direction": "horizontal"
        },
        "dataSource": [
          {
            "label": "男",
            "value": "male"
          },
          {
            "label": "女",
            "value": "female"
          },
          {
            "label": "其他",
            "value": "other"
          }
        ]
      },
      "country": {
        "type": "string",
        "title": "国家",
        "required": true,
        "component": "Select",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请选择国家"
        },
        "dataSource": [
          {
            "label": "美国",
            "value": "us"
          },
          {
            "label": "中国",
            "value": "cn"
          },
          {
            "label": "日本",
            "value": "jp"
          },
          {
            "label": "英国",
            "value": "uk"
          },
          {
            "label": "新加坡",
            "value": "sg"
          },
          {
            "label": "德国",
            "value": "de"
          }
        ]
      },
      "bio": {
        "type": "string",
        "title": "个人简介",
        "component": "Textarea",
        "decorator": "FormItem",
        "props": {
          "placeholder": "介绍一下你自己",
          "rows": 3
        },
        "validators": [
          {
            "maxLength": 200,
            "message": "个人简介不能超过 200 个字符"
          }
        ]
      },
      "agreeTerms": {
        "type": "boolean",
        "title": "我同意服务条款",
        "required": true,
        "component": "Checkbox",
        "decorator": "FormItem"
      }
    }
  },
  "category": "基础表单",
  "order": 20,
  "tags": [
    "validators",
    "dataSource",
    "props"
  ]
}
