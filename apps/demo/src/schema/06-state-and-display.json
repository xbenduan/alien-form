{
  "id": "state-and-display",
  "name": "字段状态与展示模式",
  "description": "演示 display、pattern、disabled、readOnly、readPretty、props、decoratorProps 等可变状态，便于沉淀企业级展示范式。",
  "category": "03 企业范式",
  "order": 60,
  "tags": [
    "state",
    "pattern",
    "props"
  ],
  "schema": {
    "type": "object",
    "title": "字段状态与展示模式",
    "properties": {
      "mode": {
        "type": "string",
        "title": "表单模式",
        "default": "edit",
        "component": "RadioGroup",
        "decorator": "FormItem",
        "dataSource": [
          {
            "label": "编辑",
            "value": "edit"
          },
          {
            "label": "只读",
            "value": "readonly"
          },
          {
            "label": "隐藏敏感项",
            "value": "secure"
          }
        ]
      },
      "nickname": {
        "type": "string",
        "title": "昵称",
        "default": "FormBao",
        "component": "Input",
        "decorator": "FormItem",
        "x-reaction": {
          "pattern": {
            "type": "match",
            "dependencies": {
              "mode": "mode"
            },
            "match": {
              "readonly": "readPretty",
              "default": "editable"
            }
          },
          "props": {
            "type": "expression",
            "dependencies": {
              "mode": "mode"
            },
            "expression": "{ placeholder: $deps.mode === 'readonly' ? '当前为只读模式' : '请输入昵称' }"
          }
        }
      },
      "apiSecret": {
        "type": "string",
        "title": "接口密钥",
        "default": "sk_demo_123456",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "type": "password"
        },
        "description": "权限不进入 schema 协议，推荐由 FormItem 等 decorator 范式决定是否渲染；这里仅演示 display 状态。",
        "x-reaction": {
          "display": {
            "type": "match",
            "dependencies": {
              "mode": "mode"
            },
            "match": {
              "secure": "none",
              "default": "visible"
            }
          }
        }
      },
      "reason": {
        "type": "string",
        "title": "隐藏原因",
        "component": "Textarea",
        "decorator": "FormItem",
        "props": {
          "rows": 3
        },
        "state": {
          "display": "none"
        },
        "x-reaction": {
          "display": {
            "type": "match",
            "dependencies": {
              "mode": "mode"
            },
            "match": {
              "secure": "visible",
              "default": "none"
            }
          },
          "value": {
            "type": "static",
            "value": "secure 模式下敏感字段由外层权限/装饰器范式控制，不建议写成 schema 内权限协议。"
          }
        }
      },
      "submitButtonHint": {
        "type": "string",
        "title": "提交提示",
        "default": "x-reaction 可以动态更新 props/decoratorProps/title/description 等 UI 属性",
        "component": "Input",
        "decorator": "FormItem",
        "state": {
          "pattern": "readPretty"
        },
        "x-reaction": {
          "description": {
            "type": "expression",
            "dependencies": {
              "mode": "mode"
            },
            "expression": "'当前模式：' + $deps.mode"
          }
        }
      }
    }
  }
}
