{
  "id": "x-validate",
  "name": "x-validate 动态校验",
  "description": "演示动态校验结果协议：undefined/null/true 表示通过，false/string/object/array 表示错误。",
  "category": "02 动态协议",
  "order": 50,
  "tags": [
    "x-validate",
    "expression",
    "computed"
  ],
  "schema": {
    "type": "object",
    "title": "x-validate 动态校验演示",
    "properties": {
      "username": {
        "type": "string",
        "title": "用户名",
        "default": "guest",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入 admin"
        },
        "description": "expression 返回字符串表示错误；返回 undefined 表示通过。",
        "x-validate": {
          "type": "expression",
          "expression": "$value === 'admin' ? undefined : '用户名必须是 admin'"
        }
      },
      "password": {
        "type": "string",
        "title": "密码",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "type": "password",
          "placeholder": "至少 6 位"
        },
        "validators": [
          {
            "required": true,
            "message": "请输入密码"
          },
          {
            "minLength": 6,
            "message": "密码至少 6 位"
          }
        ]
      },
      "confirmPassword": {
        "type": "string",
        "title": "确认密码",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "type": "password",
          "placeholder": "再次输入密码"
        },
        "x-validate": {
          "type": "expression",
          "dependencies": {
            "password": "password"
          },
          "expression": "$value === $deps.password ? undefined : \"两次输入的密码不一致\""
        }
      },
      "confirmCode": {
        "type": "string",
        "title": "异步确认码",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入 OK"
        },
        "description": "computed 调用应用层 checkConfirmCode handler，模拟服务端校验。",
        "x-validate": {
          "type": "computed",
          "handler": "checkConfirmCode"
        }
      }
    }
  }
}
