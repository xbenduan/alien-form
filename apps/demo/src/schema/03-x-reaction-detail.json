{
  "id": "x-reaction-detail",
  "name": "x-reaction 详解",
  "description": "集中演示 property-level x-reaction：联动渲染、联动状态、联动计算、异步加载 dataSource。",
  "category": "02 动态协议",
  "order": 30,
  "tags": ["x-reaction", "linkage", "async", "computed"],
  "schema": {
    "type": "object",
    "title": "x-reaction 详解",
    "properties": {
      "contactType": {
        "type": "string",
        "title": "联系方式",
        "default": "email",
        "component": "Select",
        "decorator": "FormItem",
        "dataSource": [
          {
            "label": "邮箱",
            "value": "email"
          },
          {
            "label": "电话",
            "value": "phone"
          },
          {
            "label": "飞书",
            "value": "lark"
          }
        ]
      },
      "email": {
        "type": "string",
        "title": "邮箱地址",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "name@example.com"
        },
        "validators": [
          {
            "format": "email",
            "message": "邮箱格式不正确"
          }
        ],
        "state": {
          "display": "visible"
        },
        "x-reaction": {
          "display": {
            "type": "match",
            "dependencies": {
              "contactType": "contactType"
            },
            "match": {
              "email": "visible",
              "default": "none"
            }
          }
        }
      },
      "phone": {
        "type": "string",
        "title": "手机号",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入手机号"
        },
        "state": {
          "display": "none"
        },
        "x-reaction": {
          "display": {
            "type": "match",
            "dependencies": {
              "contactType": "contactType"
            },
            "match": {
              "phone": "visible",
              "default": "none"
            }
          }
        }
      },
      "larkId": {
        "type": "string",
        "title": "飞书 ID",
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请输入飞书 ID"
        },
        "state": {
          "display": "none"
        },
        "x-reaction": {
          "display": {
            "type": "match",
            "dependencies": {
              "contactType": "contactType"
            },
            "match": {
              "lark": "visible",
              "default": "none"
            }
          }
        }
      },
      "quantity": {
        "type": "number",
        "title": "数量",
        "default": 2,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "type": "number"
        }
      },
      "unitPrice": {
        "type": "number",
        "title": "单价",
        "default": 99,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "type": "number"
        }
      },
      "totalPrice": {
        "type": "number",
        "title": "总价（联动计算）",
        "component": "Input",
        "decorator": "FormItem",
        "state": {
          "pattern": "readPretty"
        },
        "description": "由 quantity 与 unitPrice 通过 x-reaction.value 计算。",
        "x-reaction": {
          "value": {
            "type": "expression",
            "dependencies": {
              "quantity": "quantity",
              "unitPrice": "unitPrice"
            },
            "expression": "($deps.quantity || 0) * ($deps.unitPrice || 0)"
          }
        }
      },
      "category": {
        "type": "string",
        "title": "业务分类（异步加载）",
        "component": "Select",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请选择分类"
        },
        "x-reaction": {
          "dataSource": {
            "type": "computed",
            "handler": "fetchCategories"
          }
        }
      },
      "subCategory": {
        "type": "string",
        "title": "子分类（依赖分类刷新）",
        "component": "Select",
        "decorator": "FormItem",
        "props": {
          "placeholder": "请先选择分类"
        },
        "dataSourcePolicy": "clear",
        "description": "dataSource 变化后，如果当前值不在新选项中，会按 dataSourcePolicy.value 清空，避免展示值与候选项不匹配。",
        "x-reaction": {
          "dataSource": {
            "type": "computed",
            "dependencies": {
              "category": "category"
            },
            "handler": "fetchSubCategories"
          },
          "props": {
            "type": "expression",
            "dependencies": {
              "category": "category"
            },
            "expression": "{ placeholder: $deps.category ? '请选择子分类' : '请先选择分类' }"
          },
          "disabled": {
            "type": "expression",
            "dependencies": {
              "category": "category"
            },
            "expression": "!$deps.category"
          }
        }
      }
    }
  }
}
