{
  "id": "layout-demo",
  "name": "布局组件演示",
  "description": "使用 FormGrid、FormLayout、FormSection 组织表单布局",
  "schema": {
    "type": "object",
    "properties": {
      "basicInfo": {
        "type": "void",
        "title": "基本信息",
        "description": "个人信息以两列网格排列",
        "component": "FormSection",
        "props": {
          "bordered": true,
          "collapsible": true
        },
        "properties": {
          "basicGrid": {
            "type": "void",
            "component": "FormGrid",
            "props": {
              "columns": 2,
              "gap": 4
            },
            "properties": {
              "firstName": {
                "type": "string",
                "title": "名",
                "required": true,
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "张"
                }
              },
              "lastName": {
                "type": "string",
                "title": "姓",
                "required": true,
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "三"
                }
              },
              "email": {
                "type": "string",
                "title": "邮箱",
                "required": true,
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "john@example.com"
                },
                "validators": [
                  {
                    "format": "email",
                    "message": "邮箱格式不正确"
                  }
                ]
              },
              "phone": {
                "type": "string",
                "title": "电话",
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "+1 (555) 000-0000"
                }
              }
            }
          }
        }
      },
      "preferences": {
        "type": "void",
        "title": "偏好设置",
        "description": "沟通与通知设置",
        "component": "FormSection",
        "props": {
          "bordered": true,
          "collapsible": true
        },
        "properties": {
          "prefLayout": {
            "type": "void",
            "component": "FormLayout",
            "props": {
              "direction": "vertical",
              "gap": 3
            },
            "properties": {
              "language": {
                "type": "string",
                "title": "语言",
                "component": "Select",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "请选择语言"
                },
                "dataSource": [
                  {
                    "label": "英文",
                    "value": "en"
                  },
                  {
                    "label": "中文",
                    "value": "zh"
                  },
                  {
                    "label": "日文",
                    "value": "ja"
                  },
                  {
                    "label": "韩文",
                    "value": "ko"
                  }
                ]
              },
              "theme": {
                "type": "string",
                "title": "主题",
                "component": "RadioGroup",
                "decorator": "FormItem",
                "props": {
                  "direction": "horizontal"
                },
                "dataSource": [
                  {
                    "label": "浅色",
                    "value": "light"
                  },
                  {
                    "label": "深色",
                    "value": "dark"
                  },
                  {
                    "label": "跟随系统",
                    "value": "system"
                  }
                ]
              },
              "notifications": {
                "type": "boolean",
                "title": "开启通知",
                "component": "Switch",
                "decorator": "FormItem"
              }
            }
          }
        }
      },
      "addressSection": {
        "type": "void",
        "title": "地址",
        "description": "地址字段使用三列网格布局",
        "component": "FormSection",
        "props": {
          "bordered": true,
          "collapsible": true,
          "defaultCollapsed": true
        },
        "properties": {
          "addrGrid": {
            "type": "void",
            "component": "FormGrid",
            "props": {
              "columns": 3,
              "gap": 3
            },
            "properties": {
              "street": {
                "type": "string",
                "title": "街道",
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "世纪大道 100 号"
                }
              },
              "city": {
                "type": "string",
                "title": "城市",
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "上海"
                }
              },
              "zip": {
                "type": "string",
                "title": "邮编",
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "10001"
                }
              }
            }
          }
        }
      }
    }
  },
  "category": "布局与容器",
  "order": 40,
  "tags": [
    "void",
    "layoutProps",
    "decorator"
  ]
}
