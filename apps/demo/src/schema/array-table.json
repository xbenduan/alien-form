{
  "id": "array-table",
  "name": "表格数组演示",
  "description": "使用 ArrayTable 紧凑编辑结构化数据",
  "schema": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string",
        "title": "发票标题",
        "required": true,
        "component": "Input",
        "decorator": "FormItem",
        "props": {
          "placeholder": "例如：月度发票 #001"
        }
      },
      "lineItems": {
        "type": "array",
        "title": "条目列表",
        "component": "ArrayTable",
        "decorator": "FormItem",
        "props": {
          "addText": "+ 添加条目"
        },
        "items": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "title": "描述",
              "required": true,
              "component": "Input",
              "decorator": "FormItem",
              "props": {
                "placeholder": "条目描述"
              }
            },
            "quantity": {
              "type": "number",
              "title": "数量",
              "required": true,
              "component": "Input",
              "decorator": "FormItem",
              "props": {
                "type": "number",
                "placeholder": "0",
                "min": 1
              }
            },
            "unitPrice": {
              "type": "number",
              "title": "单价",
              "required": true,
              "component": "Input",
              "decorator": "FormItem",
              "props": {
                "type": "number",
                "placeholder": "0.00",
                "step": "0.01"
              }
            }
          }
        }
      },
      "dueDate": {
        "type": "string",
        "title": "截止日期",
        "component": "DateInput",
        "decorator": "FormItem"
      }
    }
  }
}
