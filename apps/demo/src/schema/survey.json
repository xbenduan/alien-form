{
  "id": "survey",
  "name": "问卷表单",
  "description": "包含多种输入类型的产品满意度调研",
  "schema": {
    "type": "object",
    "properties": {
      "productRating": {
        "type": "number",
        "title": "你如何评价我们的产品？",
        "required": true,
        "component": "Rating",
        "decorator": "FormItem",
        "props": {
          "max": 5,
          "size": "lg"
        }
      },
      "usedFeatures": {
        "type": "array",
        "title": "你使用过哪些功能？",
        "component": "Select",
        "decorator": "FormItem",
        "props": {
          "multiple": true,
          "placeholder": "请选择功能"
        },
        "dataSource": [
          {
            "label": "Schema 构建器",
            "value": "schema-builder"
          },
          {
            "label": "表单预览",
            "value": "preview"
          },
          {
            "label": "校验引擎",
            "value": "validation"
          },
          {
            "label": "字段联动",
            "value": "linkage"
          },
          {
            "label": "自定义组件",
            "value": "custom-components"
          }
        ]
      },
      "wouldRecommend": {
        "type": "boolean",
        "title": "你愿意推荐这款产品吗？",
        "component": "Switch",
        "decorator": "FormItem"
      },
      "improvements": {
        "type": "array",
        "title": "改进建议",
        "component": "ItemInput",
        "decorator": "FormItem",
        "props": {
          "placeholder": "输入建议后按 Enter"
        }
      },
      "feedback": {
        "type": "string",
        "title": "补充反馈",
        "component": "Textarea",
        "decorator": "FormItem",
        "props": {
          "placeholder": "欢迎补充更多想法...",
          "rows": 4
        }
      }
    }
  }
}
