{
  "id": "schema-protocol",
  "name": "Schema 协议",
  "description": "完整演示 FormBao Schema 协议：property-level reactions、$ref/definitions、state.display、state.pattern、表达式编译与 order 排序",
  "schema": {
    "type": "object",
    "title": "Schema 协议演示",
    "definitions": {
      "address": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string",
            "title": "街道",
            "component": "Input",
            "decorator": "FormItem",
            "props": {
              "placeholder": "请输入街道地址"
            },
            "state": {
              "display": "none"
            },
            "reactions": {
              "display": {
                "dependencies": {
                  "hasAddress": "conditionalSection.hasAddress"
                },
                "type": "expression",
                "expression": "$deps.hasAddress === true ? 'visible' : 'none'"
              }
            }
          },
          "city": {
            "type": "string",
            "title": "城市",
            "component": "Input",
            "decorator": "FormItem",
            "state": {
              "display": "none"
            },
            "reactions": {
              "display": {
                "dependencies": {
                  "hasAddress": "conditionalSection.hasAddress"
                },
                "type": "expression",
                "expression": "$deps.hasAddress === true ? 'visible' : 'none'"
              }
            }
          },
          "zipCode": {
            "type": "string",
            "title": "邮编",
            "component": "Input",
            "decorator": "FormItem",
            "validators": [
              {
                "pattern": "^\\d{5,6}$",
                "message": "邮编格式不正确"
              }
            ],
            "state": {
              "display": "none"
            },
            "reactions": {
              "display": {
                "dependencies": {
                  "hasAddress": "conditionalSection.hasAddress"
                },
                "type": "expression",
                "expression": "$deps.hasAddress === true ? 'visible' : 'none'"
              }
            }
          }
        }
      }
    },
    "properties": {
      "basicSection": {
        "type": "void",
        "title": "基本信息",
        "component": "FormSection",
        "props": {
          "bordered": true,
          "collapsible": true
        },
        "order": 0,
        "properties": {
          "grid1": {
            "type": "void",
            "component": "FormGrid",
            "props": {
              "columns": 2
            },
            "properties": {
              "name": {
                "type": "string",
                "title": "姓名",
                "required": true,
                "component": "Input",
                "decorator": "FormItem",
                "props": {
                  "placeholder": "请输入姓名"
                },
                "order": 0
              },
              "email": {
                "type": "string",
                "title": "邮箱",
                "required": true,
                "component": "Input",
                "decorator": "FormItem",
                "validators": [
                  {
                    "format": "email"
                  }
                ],
                "props": {
                  "placeholder": "email@example.com"
                },
                "order": 1
              }
            }
          },
          "role": {
            "type": "string",
            "title": "角色",
            "component": "Select",
            "decorator": "FormItem",
            "enum": [
              {
                "label": "开发",
                "value": "developer"
              },
              {
                "label": "设计",
                "value": "designer"
              },
              {
                "label": "管理",
                "value": "manager"
              },
              {
                "label": "其他",
                "value": "other"
              }
            ],
            "order": 2
          }
        }
      },
      "conditionalSection": {
        "type": "void",
        "title": "条件字段（property-level reactions）",
        "component": "FormSection",
        "props": {
          "bordered": true,
          "collapsible": true
        },
        "order": 1,
        "properties": {
          "hasAddress": {
            "type": "boolean",
            "title": "是否有地址？",
            "component": "Switch",
            "decorator": "FormItem",
            "order": 0
          },
          "homeAddress": {
            "$ref": "#/definitions/address",
            "title": "家庭地址（$ref）",
            "order": 1
          },
          "country": {
            "type": "string",
            "title": "国家",
            "component": "Select",
            "decorator": "FormItem",
            "enum": [
              {
                "label": "美国",
                "value": "us"
              },
              {
                "label": "中国",
                "value": "cn"
              },
              {
                "label": "日本",
                "value": "jp"
              },
              {
                "label": "英国",
                "value": "uk"
              },
              {
                "label": "德国",
                "value": "de"
              }
            ],
            "order": 2
          },
          "phone": {
            "type": "string",
            "title": "手机号（响应式占位文案）",
            "component": "Input",
            "decorator": "FormItem",
            "order": 3,
            "reactions": {
              "props": {
                "dependencies": {
                  "country": "conditionalSection.country"
                },
                "type": "expression",
                "expression": "$deps.country !== undefined && $deps.country !== '' ? { placeholder: '请输入所选国家对应的手机号' } : { placeholder: '请先选择国家' }"
              }
            }
          }
        }
      },
      "patternSection": {
        "type": "void",
        "title": "展示与模式切换",
        "component": "FormSection",
        "props": {
          "bordered": true,
          "collapsible": true
        },
        "order": 2,
        "properties": {
          "mode": {
            "type": "string",
            "title": "选择 Pattern",
            "component": "Select",
            "decorator": "FormItem",
            "default": "editable",
            "enum": [
              {
                "label": "可编辑",
                "value": "editable"
              },
              {
                "label": "只读",
                "value": "readOnly"
              },
              {
                "label": "禁用",
                "value": "disabled"
              },
              {
                "label": "阅读态",
                "value": "readPretty"
              }
            ],
            "order": 0
          },
          "demoField": {
            "type": "string",
            "title": "演示字段（随 pattern 变化）",
            "default": "你好，世界",
            "component": "Input",
            "decorator": "FormItem",
            "order": 1,
            "reactions": {
              "pattern": {
                "dependencies": {
                  "mode": "patternSection.mode"
                },
                "type": "expression",
                "expression": "$deps.mode || 'editable'"
              }
            }
          },
          "displayMode": {
            "type": "string",
            "title": "显示模式",
            "component": "Select",
            "decorator": "FormItem",
            "default": "visible",
            "enum": [
              {
                "label": "显示",
                "value": "visible"
              },
              {
                "label": "隐藏（保留占位）",
                "value": "hidden"
              },
              {
                "label": "不显示（从 DOM 移除）",
                "value": "none"
              }
            ],
            "order": 2
          },
          "displayTarget": {
            "type": "string",
            "title": "显示目标",
            "default": "我可以被隐藏！",
            "component": "Input",
            "decorator": "FormItem",
            "order": 3,
            "reactions": {
              "display": {
                "dependencies": {
                  "displayMode": "patternSection.displayMode"
                },
                "type": "expression",
                "expression": "$deps.displayMode || 'visible'"
              }
            }
          }
        }
      },
      "validationSection": {
        "type": "void",
        "title": "高级校验（JSON Schema）",
        "component": "FormSection",
        "props": {
          "bordered": true,
          "collapsible": true
        },
        "order": 3,
        "properties": {
          "age": {
            "type": "number",
            "title": "年龄（18 到 100）",
            "component": "Input",
            "decorator": "FormItem",
            "props": {
              "type": "number",
              "placeholder": "18-100"
            },
            "validators": [
              {
                "min": 18,
                "max": 100,
                "message": "年龄必须在 18 到 100 之间"
              }
            ],
            "order": 0
          },
          "score": {
            "type": "number",
            "title": "分数（必须为 5 的倍数）",
            "component": "Input",
            "decorator": "FormItem",
            "props": {
              "type": "number",
              "placeholder": "必须是 5 的倍数"
            },
            "validators": [
              {
                "multipleOf": 5,
                "message": "分数必须是 5 的倍数"
              }
            ],
            "order": 1
          },
          "website": {
            "type": "string",
            "title": "网站（URL 格式）",
            "component": "Input",
            "decorator": "FormItem",
            "props": {
              "placeholder": "https://..."
            },
            "validators": [
              {
                "format": "url",
                "message": "请输入有效的 URL"
              }
            ],
            "order": 2
          },
          "password": {
            "type": "string",
            "title": "密码（至少 8 位）",
            "required": true,
            "component": "Input",
            "decorator": "FormItem",
            "props": {
              "type": "password",
              "placeholder": "至少 8 个字符"
            },
            "validators": [
              {
                "minLength": 8,
                "message": "密码至少 8 个字符"
              }
            ],
            "order": 3
          }
        }
      }
    }
  },
  "category": "协议总览",
  "order": 100,
  "tags": [
    "protocol",
    "reactions",
    "safety"
  ]
}
