{
  "type": "object",
  "title": "会计科目",
  "properties": {
    "mdm_code": {
      "type": "string",
      "title": "MDM编码",
      "disabled": true,
      "props": {
        "placeholder": "提交后自动生成"
      }
    },
    "parent_mdm_code": {
      "type": "string",
      "title": "上级MDM编码",
      "component": "Select",
      "props": {
        "placeholder": "请输入筛选",
        "showSearch": true
      }
    },
    "parent_code": {
      "type": "string",
      "title": "上级编码"
    },
    "accounting_subject_level": {
      "type": "string",
      "title": "科目层级",
      "validate": {
        "format": "integer"
      }
    },
    "account_type": {
      "type": "string",
      "title": "科目类型"
    },
    "is_cash_or_equivalent": {
      "type": "string",
      "title": "是否现金或等价物",
      "component": "Select",
      "dataSource": [
        { "label": "是", "value": "true" },
        { "label": "否", "value": "false" }
      ]
    },
    "account_cash_type": {
      "type": "string",
      "title": "科目现金类型"
    },
    "is_relate_uniq_cash_field": {
      "type": "string",
      "title": "是否关联唯一现金字段",
      "component": "Select",
      "dataSource": [
        { "label": "是", "value": "true" },
        { "label": "否", "value": "false" }
      ]
    },
    "child_range": {
      "type": "string",
      "title": "子节点范围"
    },
    "budget_subject_mdm_code": {
      "type": "string",
      "title": "预算科目MDM编码",
      "component": "Select",
      "props": {
        "mode": "multiple",
        "showSearch": true,
        "placeholder": "请输入筛选"
      }
    },
    "using_modules": {
      "type": "string",
      "title": "使用模块",
      "component": "Select",
      "props": {
        "mode": "multiple",
        "showSearch": true
      }
    },
    "cash_borrow_field_code": {
      "type": "string",
      "title": "现金借方字段编码"
    },
    "cash_loan_field_code": {
      "type": "string",
      "title": "现金贷方字段编码"
    },
    "prc_report_field_code": {
      "type": "string",
      "title": "PRC报表字段编码"
    },
    "ifrs_report_field_code": {
      "type": "string",
      "title": "IFRS报表字段编码"
    },
    "name": {
      "type": "object",
      "title": "名称",
      "default": {
        "zh": "",
        "en": "",
        "ja": ""
      },
      "properties": {
        "zh": {
          "type": "string",
          "title": "中文",
          "props": {
            "placeholder": "请输入"
          }
        },
        "en": {
          "type": "string",
          "title": "English",
          "props": {
            "placeholder": "请输入"
          }
        },
        "ja": {
          "type": "string",
          "title": "日本語",
          "props": {
            "placeholder": "请输入"
          }
        }
      }
    },
    "code_e": {
      "type": "string",
      "title": "编码(英文)",
      "validate": {
        "maxLength": 20
      },
      "props": {
        "maxLength": 20
      }
    }
  }
}
