{
  "type": "object",
  "title": "Article Workspace",
  "description": "用一份 schema 同时驱动筛选、列表、新增、编辑、详情五种后台能力。",
  "x-model": {
    "name": "article",
    "title": "内容模型工作台",
    "subtitle": "Article",
    "description": "基于 alien-form 的 schema-driven 单页 CMS 验证应用。",
    "singularLabel": "文章",
    "pluralLabel": "文章",
    "primaryField": "title",
    "defaultPageSize": 5,
    "openMode": {
      "add": "drawer",
      "edit": "drawer",
      "detail": "modal"
    },
    "filter": {
      "count": 3
    }
  },
  "properties": {
    "title": {
      "type": "string",
      "title": "文章标题",
      "description": "用作列表主标题与详情标题。",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 10,
      "props": {
        "placeholder": "请输入文章标题"
      },
      "x-cms": {
        "table": {
          "width": 260,
          "ellipsis": true
        }
      }
    },
    "status": {
      "type": "string",
      "title": "状态",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 20,
      "dataSource": [
        {
          "label": "草稿",
          "value": "draft"
        },
        {
          "label": "待发布",
          "value": "review"
        },
        {
          "label": "已发布",
          "value": "published"
        },
        {
          "label": "已归档",
          "value": "archived"
        }
      ],
      "props": {
        "placeholder": "请选择状态"
      },
      "x-cms": {
        "table": {
          "width": 120,
          "format": "status"
        }
      }
    },
    "category": {
      "type": "string",
      "title": "分类",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 30,
      "dataSource": [
        {
          "label": "产品设计",
          "value": "product"
        },
        {
          "label": "工程实践",
          "value": "engineering"
        },
        {
          "label": "增长运营",
          "value": "growth"
        },
        {
          "label": "团队协作",
          "value": "team"
        }
      ],
      "props": {
        "placeholder": "请选择分类"
      },
      "x-cms": {
        "table": {
          "width": 140
        }
      }
    },
    "author": {
      "type": "string",
      "title": "作者",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 40,
      "props": {
        "placeholder": "请输入作者"
      },
      "x-cms": {
        "table": {
          "width": 140
        }
      }
    },
    "publishTime": {
      "type": "string",
      "title": "发布时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "required": true,
      "order": 50,
      "props": {
        "placeholder": "请选择发布时间"
      },
      "x-cms": {
        "table": {
          "width": 160,
          "format": "date"
        },
        "detail": {
          "format": "dateTime"
        }
      }
    },
    "readingTime": {
      "type": "number",
      "title": "阅读时长(分钟)",
      "component": "NumberInput",
      "decorator": "FormItem",
      "required": true,
      "order": 60,
      "props": {
        "placeholder": "请输入预估阅读时长",
        "min": 1,
        "max": 60
      },
      "x-cms": {
        "table": {
          "width": 140
        }
      }
    },
    "featured": {
      "type": "boolean",
      "title": "首页推荐",
      "component": "Switch",
      "decorator": "FormItem",
      "order": 70,
      "default": false,
      "x-cms": {
        "table": {
          "width": 120,
          "format": "boolean"
        },
        "detail": {
          "format": "boolean"
        }
      }
    },
    "tags": {
      "type": "array",
      "title": "标签",
      "component": "TagsInput",
      "decorator": "FormItem",
      "order": 80,
      "default": [],
      "x-cms": {
        "table": {
          "width": 220,
          "ellipsis": true
        }
      }
    },
    "summary": {
      "type": "string",
      "title": "摘要",
      "component": "Textarea",
      "decorator": "FormItem",
      "required": true,
      "order": 90,
      "props": {
        "rows": 4,
        "placeholder": "请输入摘要"
      }
    },
    "content": {
      "type": "string",
      "title": "正文",
      "component": "Textarea",
      "decorator": "FormItem",
      "required": true,
      "order": 100,
      "props": {
        "rows": 8,
        "placeholder": "请输入正文内容"
      }
    },
    "createdAt": {
      "type": "string",
      "title": "创建时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 110,
      "x-cms": {
        "form": {
          "modes": []
        },
        "detail": {
          "format": "dateTime"
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "title": "更新时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 120,
      "x-cms": {
        "form": {
          "modes": []
        },
        "table": {
          "width": 170,
          "format": "dateTime"
        },
        "detail": {
          "format": "dateTime"
        }
      }
    }
  }
}
