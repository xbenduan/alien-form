            },
            {
              "label": "华东",
              "value": "east"
            },
            {
              "label": "华南",
              "value": "south"
            },
            {
              "label": "全国",
              "value": "nationwide"
            }
          ],
          "props": {
            "placeholder": "请选择区域"
          }
        },
        "audienceType": {
          "type": "string",
          "title": "人群",
          "component": "Select",
          "decorator": "FormItem",
          "order": 20,
          "dataSource": [
            {
              "label": "新客",
              "value": "new"
            },
            {
              "label": "活跃老客",
              "value": "active"
            },
            {
              "label": "沉默老客",
              "value": "inactive"
            },
            {
              "label": "高潜线索",
              "value": "lead"
            }
          ],
          "props": {
            "placeholder": "请选择人群"
          }
        },
        "priority": {
          "type": "string",
          "title": "优先级",
          "component": "Select",
          "decorator": "FormItem",
          "order": 30,
          "dataSource": [
            {
              "label": "高",
              "value": "high"
            },
            {
              "label": "中",
              "value": "medium"
            },
            {
              "label": "低",
              "value": "low"
            }
          ],
          "props": {
            "placeholder": "请选择优先级"
          }
        },
        "notes": {
          "type": "string",
          "title": "投放备注",
          "component": "Textarea",
          "decorator": "FormItem",
          "order": 40,
          "props": {
            "rows": 3,
            "placeholder": "请输入定向补充说明"
          }
        }
      },
      "x-cms": {
        "table": {
          "width": 260,
          "inline": [
            "region",
            "audienceType",
            "priority"
          ],
          "expandable": true
        }
      }
    },
    "deliverySection": {
      "type": "void",
      "title": "投放补充信息",
      "component": "SectionCard",
      "order": 86,
      "properties": {
        "landingPage": {
          "type": "string",
          "title": "落地页地址",
          "component": "Input",
          "decorator": "FormItem",
          "order": 10,
          "props": {
            "placeholder": "请输入落地页地址"
          }
        },
        "trackingCode": {
          "type": "string",
          "title": "追踪编码",
          "component": "Input",
          "decorator": "FormItem",
          "order": 20,
          "props": {
            "placeholder": "请输入追踪编码"
          }
        },
        "syncCrm": {
          "type": "boolean",
          "title": "同步到 CRM",
          "component": "Switch",
          "decorator": "FormItem",
          "order": 30,
          "x-cms": {
            "detail": {
              "format": "boolean"
            }
          }
        },
        "deliveryNotes": {
          "type": "string",
          "title": "投放说明",
          "component": "Textarea",
          "decorator": "FormItem",
          "order": 40,
          "props": {
            "rows": 3,
            "placeholder": "请输入投放说明"
          }
        }
      }
    },
    "materials": {
      "type": "array",
      "title": "素材清单",
      "component": "ArrayCards",
      "decorator": "FormItem",
      "order": 87,
      "props": {
        "addText": "+ 添加素材"
      },
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "title": "素材名称",
            "component": "Input",
            "decorator": "FormItem",
            "required": true,
            "order": 10,
            "props": {
              "placeholder": "请输入素材名称"
            }
          },
          "format": {
            "type": "string",
            "title": "素材类型",
            "component": "Select",
            "decorator": "FormItem",
            "order": 20,
            "dataSource": [
              {
                "label": "Banner",
                "value": "banner"
              },
              {
                "label": "短视频",
                "value": "video"
              },
              {
                "label": "落地页",
                "value": "landing"
              }
            ],
            "props": {
              "placeholder": "请选择素材类型"
            }
          },
          "owner": {
            "type": "string",
            "title": "素材负责人",
            "component": "Input",
            "decorator": "FormItem",
            "order": 30,
            "props": {
              "placeholder": "请输入素材负责人"
            }
          },
          "enabled": {
            "type": "boolean",
            "title": "启用中",
            "component": "Switch",
            "decorator": "FormItem",
            "order": 40,
            "x-cms": {
              "detail": {
                "format": "boolean"
              }
            }
          }
        }
      },
      "default": [],
      "x-cms": {
        "table": {
          "width": 220,
          "inline": [
            "name",
            "format"
          ],
          "expandable": true
        }
      }
    },
    "summary": {
      "type": "string",
      "title": "活动摘要",
      "component": "Textarea",
      "decorator": "FormItem",
      "required": true,
      "order": 90,
      "props": {
        "rows": 4,
        "placeholder": "请输入活动摘要"
      }
    },
    "goal": {
      "type": "string",
      "title": "活动目标",
      "component": "Textarea",
      "decorator": "FormItem",
      "required": true,
      "order": 100,
      "props": {
        "rows": 8,
        "placeholder": "请输入活动目标"
      }
    },
    "createdAt": {
      "type": "string",
      "title": "创建时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 110,
      "x-cms": {
        "form": {
          "modes": []
        },
        "detail": {
          "format": "dateTime"
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "title": "更新时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 120,
      "x-cms": {
        "form": {
          "modes": []
        },
        "table": {
          "width": 170,
          "format": "dateTime"
        },
        "detail": {
          "format": "dateTime"
        }
      }
    }
