{
  "type": "object",
  "title": "Campaign Workspace",
  "description": "通过第二个模型验证同一套 schema projection、Dexie provider 与单页工作台的复用能力。",
  "x-model": {
    "name": "campaign",
    "title": "增长活动工作台",
    "subtitle": "Campaign",
    "description": "使用另一份 schema 验证 URL 驱动的多模型工作台。",
    "singularLabel": "活动",
    "pluralLabel": "活动",
    "primaryField": "name",
    "defaultPageSize": 5,
    "openMode": {
      "add": "page",
      "edit": "page",
      "detail": "page"
    },
    "filter": {
      "count": 3
    }
  },
  "properties": {
    "name": {
      "type": "string",
      "title": "活动名称",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 10,
      "props": {
        "placeholder": "请输入活动名称"
      },
      "x-cms": {
        "table": {
          "width": 240,
          "ellipsis": true
        }
      }
    },
    "status": {
      "type": "string",
      "title": "状态",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 20,
      "dataSource": [
        {
          "label": "规划中",
          "value": "draft"
        },
        {
          "label": "执行中",
          "value": "review"
        },
        {
          "label": "已上线",
          "value": "published"
        },
        {
          "label": "已结束",
          "value": "archived"
        }
      ],
      "props": {
        "placeholder": "请选择活动状态"
      },
      "x-cms": {
        "table": {
          "width": 120,
          "format": "status"
        }
      }
    },
    "channel": {
      "type": "string",
      "title": "渠道",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 30,
      "dataSource": [
        {
          "label": "搜索投放",
          "value": "search"
        },
        {
          "label": "社媒分发",
          "value": "social"
        },
        {
          "label": "邮件触达",
          "value": "email"
        },
        {
          "label": "社区运营",
          "value": "community"
        }
      ],
      "props": {
        "placeholder": "请选择投放渠道"
      },
      "x-cms": {
        "table": {
          "width": 140
        }
      }
    },
    "owner": {
      "type": "string",
      "title": "负责人",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 40,
      "props": {
        "placeholder": "请输入负责人"
      },
      "x-cms": {
        "table": {
          "width": 140
        }
      }
    },
    "launchDate": {
      "type": "string",
      "title": "上线日期",
      "component": "DateInput",
      "decorator": "FormItem",
      "required": true,
      "order": 50,
      "props": {
        "placeholder": "请选择上线日期"
      },
      "x-cms": {
        "table": {
          "width": 160,
          "format": "date"
        },
        "detail": {
          "format": "dateTime"
        }
      }
    },
    "budget": {
      "type": "number",
      "title": "预算(万元)",
      "component": "NumberInput",
      "decorator": "FormItem",
      "required": true,
      "order": 60,
      "props": {
        "placeholder": "请输入预算",
        "min": 1,
        "max": 999
      },
      "x-cms": {
        "table": {
          "width": 130
        }
      }
    },
    "active": {
      "type": "boolean",
      "title": "是否启用",
      "component": "Switch",
      "decorator": "FormItem",
      "order": 70,
      "default": true,
      "x-cms": {
        "table": {
          "width": 120,
          "format": "boolean"
        },
        "detail": {
          "format": "boolean"
        }
      }
    },
    "tags": {
      "type": "array",
      "title": "标签",
      "component": "TagsInput",
