{
  "type": "object",
  "title": "Campaign Workspace",
  "description": "通过第二个模型验证同一套 schema projection、Dexie provider 与单页工作台的复用能力。",
  "x-model": {
    "name": "campaign",
    "title": "增长活动工作台",
    "subtitle": "Campaign",
    "description": "使用另一份 schema 验证 URL 驱动的多模型工作台。",
    "singularLabel": "活动",
    "pluralLabel": "活动",
    "primaryField": "name",
    "defaultFilterCount": 3,
    "defaultPageSize": 6
  },
  "properties": {
    "name": {
      "type": "string",
      "title": "活动名称",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 10,
      "props": {
        "placeholder": "请输入活动名称"
      },
      "x-cms": {
        "filter": {
          "visible": true,
          "defaultVisible": true,
          "operator": "contains"
        },
        "table": {
          "visible": true,
          "width": 240,
          "ellipsis": true
        },
        "detail": {
          "visible": true
        }
      }
    },
    "status": {
      "type": "string",
      "title": "状态",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 20,
      "dataSource": [
        { "label": "规划中", "value": "draft" },
        { "label": "执行中", "value": "review" },
        { "label": "已上线", "value": "published" },
        { "label": "已结束", "value": "archived" }
      ],
      "props": {
        "placeholder": "请选择活动状态"
      },
      "x-cms": {
        "filter": {
          "visible": true,
          "defaultVisible": true,
          "operator": "eq"
        },
        "table": {
          "visible": true,
          "width": 120,
          "format": "status"
        },
        "detail": {
          "visible": true
        }
      }
    },
    "channel": {
      "type": "string",
      "title": "渠道",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 30,
      "dataSource": [
        { "label": "搜索投放", "value": "search" },
        { "label": "社媒分发", "value": "social" },
        { "label": "邮件触达", "value": "email" },
        { "label": "社区运营", "value": "community" }
      ],
      "props": {
        "placeholder": "请选择投放渠道"
      },
      "x-cms": {
        "filter": {
          "visible": true,
          "defaultVisible": true,
          "operator": "eq"
        },
        "table": {
          "visible": true,
          "width": 140
        },
        "detail": {
          "visible": true
        }
      }
    },
    "owner": {
      "type": "string",
      "title": "负责人",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 40,
      "props": {
        "placeholder": "请输入负责人"
      },
      "x-cms": {
        "filter": {
          "visible": true,
          "operator": "contains"
        },
        "table": {
          "visible": true,
          "width": 140
        },
        "detail": {
          "visible": true
        }
      }
    },
    "launchDate": {
      "type": "string",
      "title": "上线日期",
      "component": "DateInput",
      "decorator": "FormItem",
      "required": true,
      "order": 50,
      "props": {
        "placeholder": "请选择上线日期"
      },
      "x-cms": {
        "filter": {
          "visible": true,
          "operator": "eq"
        },
        "table": {
          "visible": true,
          "width": 160,
          "format": "date"
        },
        "detail": {
          "visible": true,
          "format": "dateTime"
        }
      }
    },
    "budget": {
      "type": "number",
      "title": "预算(万元)",
      "component": "NumberInput",
      "decorator": "FormItem",
      "required": true,
      "order": 60,
      "props": {
        "placeholder": "请输入预算",
        "min": 1,
        "max": 999
      },
      "x-cms": {
        "filter": {
          "visible": true,
          "operator": "eq"
        },
        "table": {
          "visible": true,
          "width": 130
        },
        "detail": {
          "visible": true
        }
      }
    },
    "active": {
      "type": "boolean",
      "title": "是否启用",
      "component": "Switch",
      "decorator": "FormItem",
      "order": 70,
      "default": true,
      "x-cms": {
        "filter": {
          "visible": true,
          "operator": "eq"
        },
        "table": {
          "visible": true,
          "width": 120,
          "format": "boolean"
        },
        "detail": {
          "visible": true,
          "format": "boolean"
        }
      }
    },
    "tags": {
      "type": "array",
      "title": "标签",
      "component": "TagsInput",
      "decorator": "FormItem",
      "order": 80,
      "default": [],
      "x-cms": {
        "filter": {
          "visible": false
        },
        "table": {
          "visible": true,
          "width": 220,
          "ellipsis": true
        },
        "detail": {
          "visible": true
        }
      }
    },
    "summary": {
      "type": "string",
      "title": "活动摘要",
      "component": "Textarea",
      "decorator": "FormItem",
      "required": true,
      "order": 90,
      "props": {
        "rows": 4,
        "placeholder": "请输入活动摘要"
      },
      "x-cms": {
        "filter": {
          "visible": false
        },
        "table": {
          "visible": false
        },
        "detail": {
          "visible": true
        }
      }
    },
    "goal": {
      "type": "string",
      "title": "活动目标",
      "component": "Textarea",
      "decorator": "FormItem",
      "required": true,
      "order": 100,
      "props": {
        "rows": 8,
        "placeholder": "请输入活动目标"
      },
      "x-cms": {
        "filter": {
          "visible": false
        },
        "table": {
          "visible": false
        },
        "detail": {
          "visible": true
        }
      }
    },
    "createdAt": {
      "type": "string",
      "title": "创建时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 110,
      "x-cms": {
        "form": {
          "modes": []
        },
        "filter": {
          "visible": false
        },
        "table": {
          "visible": false
        },
        "detail": {
          "visible": true,
          "format": "dateTime"
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "title": "更新时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 120,
      "x-cms": {
        "form": {
          "modes": []
        },
        "filter": {
          "visible": false
        },
        "table": {
          "visible": true,
          "width": 170,
          "format": "dateTime"
        },
        "detail": {
          "visible": true,
          "format": "dateTime"
        }
      }
    }
  }
}
