{
  "type": "object",
  "title": "Nail Booking Workspace",
  "description": "用第三个模型验证生活服务场景下的预约、服务偏好与到店信息管理。",
  "x-model": {
    "name": "nail-booking",
    "title": "美甲预约平台",
    "subtitle": "Nail Booking",
    "description": "面向门店预约场景的轻量后台模型，验证预约记录在筛选、表格、表单与详情中的统一投影。",
    "singularLabel": "预约",
    "pluralLabel": "预约",
    "primaryField": "customerName",
    "defaultPageSize": 5,
    "openMode": {
      "add": "modal",
      "edit": "modal",
      "detail": "modal"
    },
    "filter": {
      "count": 3
    }
  },
  "properties": {
    "customerName": {
      "type": "string",
      "title": "预约人",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 10,
      "props": {
        "placeholder": "请输入预约人姓名"
      },
      "x-cms": {
        "table": {
          "width": 160
        }
      }
    },
    "phone": {
      "type": "string",
      "title": "联系电话",
      "component": "Input",
      "decorator": "FormItem",
      "required": true,
      "order": 20,
      "props": {
        "placeholder": "请输入联系电话"
      },
      "x-cms": {
        "table": {
          "width": 160
        }
      }
    },
    "bookingDate": {
      "type": "string",
      "title": "预约日期",
      "component": "DateInput",
      "decorator": "FormItem",
      "required": true,
      "order": 30,
      "props": {
        "placeholder": "请选择预约日期"
      },
      "x-cms": {
        "table": {
          "width": 150,
          "format": "date"
        },
        "detail": {
          "format": "dateTime"
        }
      }
    },
    "bookingSlot": {
      "type": "string",
      "title": "预约时段",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 40,
      "dataSource": [
        {
          "label": "10:00",
          "value": "10:00"
        },
        {
          "label": "12:00",
          "value": "12:00"
        },
        {
          "label": "14:00",
          "value": "14:00"
        },
        {
          "label": "16:00",
          "value": "16:00"
        },
        {
          "label": "18:00",
          "value": "18:00"
        }
      ],
      "props": {
        "placeholder": "请选择预约时段"
      },
      "x-cms": {
        "table": {
          "width": 120
        }
      }
    },
    "serviceType": {
      "type": "string",
      "title": "服务类型",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 50,
      "dataSource": [
        {
          "label": "单色基础款",
          "value": "basic"
        },
        {
          "label": "法式轻设计",
          "value": "french"
        },
        {
          "label": "猫眼跳色款",
          "value": "cat-eye"
        },
        {
          "label": "节日定制款",
          "value": "festival"
        }
      ],
      "props": {
        "placeholder": "请选择服务类型"
      },
      "x-cms": {
        "table": {
          "width": 150
        }
      }
    },
    "nailArtist": {
      "type": "string",
      "title": "美甲师",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 60,
      "dataSource": [
        {
          "label": "Luna",
          "value": "luna"
        },
        {
          "label": "Momo",
          "value": "momo"
        },
        {
          "label": "Kiki",
          "value": "kiki"
        },
        {
          "label": "Nora",
          "value": "nora"
        }
      ],
      "props": {
        "placeholder": "请选择美甲师"
      },
      "x-cms": {
        "table": {
          "width": 120
        }
      }
    },
    "branch": {
      "type": "string",
      "title": "预约门店",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 70,
      "dataSource": [
        {
          "label": "国贸店",
          "value": "guomao"
        },
        {
          "label": "静安店",
          "value": "jingan"
        },
        {
          "label": "万象城店",
          "value": "mixc"
        }
      ],
      "props": {
        "placeholder": "请选择预约门店"
      },
      "x-cms": {
        "table": {
          "width": 140
        }
      }
    },
    "status": {
      "type": "string",
      "title": "预约状态",
      "component": "Select",
      "decorator": "FormItem",
      "required": true,
      "order": 80,
      "dataSource": [
        {
          "label": "待确认",
          "value": "draft"
        },
        {
          "label": "已确认",
          "value": "review"
        },
        {
          "label": "已到店",
          "value": "published"
        },
        {
          "label": "已取消",
          "value": "archived"
        }
      ],
      "props": {
        "placeholder": "请选择预约状态"
      },
      "x-cms": {
        "table": {
          "width": 120,
          "format": "status"
        }
      }
    },
    "depositPaid": {
      "type": "boolean",
      "title": "已付定金",
      "component": "Switch",
      "decorator": "FormItem",
      "order": 90,
      "default": false,
      "x-cms": {
        "table": {
          "width": 120,
          "format": "boolean"
        },
        "detail": {
          "format": "boolean"
        }
      }
    },
    "styleTags": {
      "type": "array",
      "title": "风格标签",
      "component": "TagsInput",
      "decorator": "FormItem",
      "order": 100,
      "default": [],
      "x-cms": {
        "table": {
          "width": 220,
          "ellipsis": true
        }
      }
    },
    "preferences": {
      "type": "object",
      "title": "偏好配置",
      "component": "SectionCard",
      "order": 110,
      "properties": {
        "shape": {
          "type": "string",
          "title": "甲型偏好",
          "component": "Select",
          "decorator": "FormItem",
          "order": 10,
          "dataSource": [
            {
              "label": "圆形",
              "value": "round"
            },
            {
              "label": "方圆",
              "value": "squoval"
            },
            {
              "label": "杏仁",
              "value": "almond"
            }
          ],
          "props": {
            "placeholder": "请选择甲型偏好"
          }
        },
        "colorTone": {
          "type": "string",
          "title": "颜色偏好",
          "component": "Select",
          "decorator": "FormItem",
          "order": 20,
          "dataSource": [
            {
              "label": "奶油裸色",
              "value": "nude"
            },
            {
              "label": "酒红系",
              "value": "red"
            },
            {
              "label": "低饱和跳色",
              "value": "mix"
            }
          ],
          "props": {
            "placeholder": "请选择颜色偏好"
          }
        },
        "specialNotes": {
          "type": "string",
          "title": "备注偏好",
          "component": "Textarea",
          "decorator": "FormItem",
          "order": 30,
          "props": {
            "rows": 3,
            "placeholder": "请输入偏好备注"
          }
        }
      },
      "x-cms": {
        "table": {
          "width": 220,
          "inline": [
            "shape",
            "colorTone"
          ],
          "expandable": true
        }
      }
    },
    "serviceItems": {
      "type": "array",
      "title": "预约项目",
      "component": "ArrayCards",
      "decorator": "FormItem",
      "order": 120,
      "props": {
        "addText": "+ 添加项目"
      },
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "title": "项目名称",
            "component": "Input",
            "decorator": "FormItem",
            "required": true,
            "order": 10,
            "props": {
              "placeholder": "请输入项目名称"
            }
          },
          "duration": {
            "type": "number",
            "title": "耗时(分钟)",
            "component": "NumberInput",
            "decorator": "FormItem",
            "order": 20,
            "props": {
              "placeholder": "请输入耗时"
            }
          },
          "price": {
            "type": "number",
            "title": "价格",
            "component": "NumberInput",
            "decorator": "FormItem",
            "order": 30,
            "props": {
              "placeholder": "请输入价格"
            }
          }
        }
      },
      "default": [],
      "x-cms": {
        "table": {
          "width": 220,
          "inline": [
            "name",
            "duration"
          ],
          "expandable": true
        }
      }
    },
    "remark": {
      "type": "string",
      "title": "预约备注",
      "component": "Textarea",
      "decorator": "FormItem",
      "order": 130,
      "props": {
        "rows": 4,
        "placeholder": "请输入预约备注"
      }
    },
    "createdAt": {
      "type": "string",
      "title": "创建时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 140,
      "x-cms": {
        "form": {
          "modes": []
        },
        "detail": {
          "format": "dateTime"
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "title": "更新时间",
      "component": "DateInput",
      "decorator": "FormItem",
      "order": 150,
      "x-cms": {
        "form": {
          "modes": []
        },
        "table": {
          "width": 170,
          "format": "dateTime"
        },
        "detail": {
          "format": "dateTime"
        }
      }
    }
  }
}
