{
  "lsp": {
    "oxfmt": {},
    "oxlint": {}
  },
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on"
    },
    "TypeScript": {
