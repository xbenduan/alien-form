{
  "name": "alien-form",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @alien-form/demo run dev",
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @alien-form/core run build",
    "build:react": "pnpm --filter @alien-form/react run build",
    "test": "pnpm -r run test",
    "test:core": "pnpm --filter @alien-form/core run test",
    "lint": "oxlint --deny-warnings",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "docs:dev": "pnpm --filter @alien-form/docs dev",
    "docs:build": "pnpm --filter @alien-form/docs build",
    "docs:preview": "pnpm --filter @alien-form/docs preview"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.4.0"
  }
}
