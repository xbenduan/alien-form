{
  "name": "alien-form",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @alien-form/core run build && pnpm --filter @alien-form/example run dev",
    "dev:docs": "pnpm --filter @alien-form/docs run dev",
    "build": "pnpm -r run build",
    "lint": "oxlint --deny-warnings",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.4.0"
  }
}
